# ─── Shared / network ────────────────────────────────────────────────
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_EXPLORER_BASE=https://suiscan.xyz/testnet

# ─── Deployed Move package (fill after `sui client publish` + seed) ──
# Values are written to contracts/lp_guardian/deployment.json by scripts/seed_demo.js
LPG_PACKAGE_ID=0x0
# Deployer / owner of the demo portfolios. Demo StrategistCaps are held by this address
# (agent==owner for seeding). BE Agent: re-authorize the real watcher address before going live.
LPG_OWNER_ADDRESS=0x0

# Primary demo portfolio (Demo1-Amber: the hero story).
LPG_PORTFOLIO_ID=0x0

# Whitelisted pool ids the agent may target in rebalance (Move enforces this).
# Comma-separated; copy from contracts/lp_guardian/deployment.json "whitelist".
LPG_WHITELIST=
# Optional explicit wallet→portfolio mapping (JSON), e.g. {"0xabc":"0x40fc..."}.
# If omitted, pass a portfolioId directly as walletAddress to pick a demo.
LPG_WALLET_PORTFOLIO_MAP=

# Full demo set (Amber / Red / Green) — see contracts/lp_guardian/deployment.json
LPG_DEMO_AMBER_PORTFOLIO=0x0
LPG_DEMO_AMBER_CAP=0x0
LPG_DEMO_AMBER_REPORT=0x0
LPG_DEMO_RED_PORTFOLIO=0x0
LPG_DEMO_RED_CAP=0x0
LPG_DEMO_RED_REPORT=0x0
LPG_DEMO_GREEN_PORTFOLIO=0x0
LPG_DEMO_GREEN_CAP=0x0
LPG_DEMO_GREEN_REPORT=0x0

# ─── BE Agent (apps/server) ──────────────────────────────────────────
PORT=8787
BE_DATA_URL=http://localhost:8000
# Strategist / Watcher signer (agent key — NEVER the user's key). Holds StrategistCap only.
STRATEGIST_PRIVATE_KEY=
# Autonomous watcher
WATCHER_ENABLED=true
WATCHER_POLL_MS=5000

# ─── External data ───────────────────────────────────────────────────
PYTH_HERMES_URL=https://hermes.pyth.network
CETUS_API_URL=
TURBOS_API_URL=

# ─── MCP server (apps/mcp-server) ────────────────────────────────────
LPG_API_BASE=http://localhost:8787
LPG_WEB_BASE=http://localhost:5173

# ─── Web (apps/web) ──────────────────────────────────────────────────
VITE_API_BASE=http://localhost:8787
VITE_SUI_NETWORK=testnet
