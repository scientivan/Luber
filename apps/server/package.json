{
  "name": "@lp-guardian/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --conditions=development src/index.ts",
    "start": "node dist/index.js",
    "prebuild": "pnpm --filter @lp-guardian/core build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "watcher": "tsx --conditions=development src/agents/watcher.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.83",
    "@hono/node-server": "^1.13.8",
    "@lp-guardian/core": "workspace:*",
    "@mysten/deepbook-v3": "^0.12.0",
    "@mysten/sui": "^1.18.0",
    "ai": "^6.0.208",
    "dotenv": "^17.4.2",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
